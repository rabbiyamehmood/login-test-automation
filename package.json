{
  "name": "simple-login-automation",
  "version": "1.0.0",
  "description": "Simple Playwright login test automation",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:login": "playwright test tests/simple-login.spec.js",
    "test:ci": "playwright test --reporter=html,json",
    "install:browsers": "npx playwright install",
    "show:report": "npx playwright show-report"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "login",
    "ci-cd"
  ],
  "author": "Your Name",
